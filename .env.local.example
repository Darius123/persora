# --- 0G COMPUTE (production) ---
# Get your key at https://pc.0g.ai (or ask in 0G Discord for hackathon credits)
ZG_API_KEY=

# Model to use — available: deepseek-v4-flash, deepseek-v4-pro, qwen3.7-max, 0gm-1.0-35b-a3b, glm-5.1
ZG_MODEL=deepseek-v4-flash

# --- ANTHROPIC (dev fallback — used when ZG_API_KEY and ZG_PRIVATE_KEY are not set) ---
ANTHROPIC_API_KEY=

# --- 0G STORAGE ---
# Wallet private key for signing uploads to 0G Storage (testnet)
ZG_PRIVATE_KEY=

# Public base URL for shareable verdict links
NEXT_PUBLIC_BASE_URL=http://localhost:3000
